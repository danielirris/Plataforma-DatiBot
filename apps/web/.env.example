# Variables de entorno del shell (web) en producción (EasyPanel).
# Copia estas claves al panel del servicio "web". NO pongas aquí valores reales.

# ── Login de toda la plataforma (Basic Auth) ──────────────────
# Si defines ambas, todo el shell (incluida /api/config) queda tras login.
# Si las dejas vacías, la plataforma queda abierta (solo para local).
APP_AUTH_USER=
APP_AUTH_PASSWORD=

# ── Persistencia ──────────────────────────────────────────────
# Carpeta (volumen montado) donde se guardan .config-store.json y .products-store.
# En EasyPanel monta un volumen en /data y pon DATA_DIR=/data.
DATA_DIR=/data

# ── URLs de los servicios embebidos (iframes) ─────────────────
# Se leen en runtime (no llevan NEXT_PUBLIC_). Apuntan a los subdominios
# públicos de cada servicio en producción.
DASHBOARD_URL=https://dashboard.tudominio.com
EXTRACTOR_URL=https://extractor.tudominio.com
EBOOKFORGE_URL=https://ebooks.tudominio.com

# ── Render de ebooks desde Productos (server-side) ────────────
# URL INTERNA del servicio de ebooks (misma red del proyecto EasyPanel), para
# que el botón "Generar ebook" de Productos renderice el PDF. Debe ser la
# interna (no la pública), porque la pública lleva Basic Auth y bloquearía la
# llamada del servidor. En EasyPanel suele ser http://<proyecto>_ebooks:8600.
EBOOK_RENDER_URL=http://ebooks:8600

# ── Claves del shell por ENTORNO (opcional) ───────────────────
# El shell lee sus claves del panel /configuracion (volumen /data), PERO el
# entorno GANA: define estas variables aquí y persisten entre redeploys sin
# depender del volumen. Nombre = <GRUPO>_<CAMPO> en mayúsculas.
#
# Esenciales (para que Productos y la generación de ebooks funcionen):
IA_GEMINI_API_KEY=
IA_TEXT_PROVIDER=Gemini            # o "OpenAI"
COMPARTIDAS_OPENAI_API_KEY=        # solo si usas OpenAI o lo compartes
# Subida de imágenes de Productos (SFTP al VPS):
VPS_VPS_HOST=
VPS_VPS_PORT=22
VPS_VPS_USER=
VPS_VPS_AUTH=
VPS_VPS_REMOTE_DIR=
VPS_VPS_PUBLIC_BASE_URL=
# Creador de Flujos (solo si lo usas): FLUJOS_GENERAL_* y FLUJOS_PE/CL/CO_*
# (categoria_producto, drive_contenido, forms_*, capi_token, chatwoot_token,
#  pixel_id, phone_id, account_id, page_id).

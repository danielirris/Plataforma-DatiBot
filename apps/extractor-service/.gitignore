# Entorno / secretos
.env
.env.local

# Almacenamiento de trabajo (uploads, temporales, outputs). Se usa "storage/*"
# (no "storage/") para que git PUEDA descender y re-incluir la biblioteca base.
storage/*
# EXCEPCIÓN: la biblioteca base (música de fondo + sfx) SÍ se versiona — es la
# que el motor usa por defecto y debe viajar dentro de la imagen Docker.
!storage/library/
!storage/library/music/
!storage/library/sfx/
!storage/library/music/*.m4a
!storage/library/sfx/*.m4a

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Medios (por si acaso, fuera de storage/)
*.mp4
*.mov
*.mkv
*.wav
*.mp3
*.m4a
# …salvo la biblioteca base, que sí se versiona (ver arriba).
!storage/library/music/*.m4a
!storage/library/sfx/*.m4a

# Sistema / editores
.DS_Store
.idea/
.vscode/
*.log

# Tooling local
.claude/

# FFmpeg local con libass (no subir el binario)
bin/

node_modules/
